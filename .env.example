# Azure Speech Service Configuration
AZURE_SPEECH_KEY=your_speech_service_key_here
AZURE_SPEECH_REGION=your_speech_service_region_here

# Azure Language Service Configuration
AZURE_LANGUAGE_KEY=your_language_service_key_here
AZURE_LANGUAGE_REGION=your_language_service_region_here

# Azure Translator Configuration
AZURE_TRANSLATOR_KEY=your_translator_key_here
AZURE_TRANSLATOR_REGION=your_translator_region_here

# Application Configuration
APP_NAME=Azure Voice Language Lab
APP_VERSION=1.0.0
DEBUG=False

# Audio Configuration
DEFAULT_AUDIO_FORMAT=wav
DEFAULT_SAMPLE_RATE=16000
DEFAULT_CHANNELS=1

# Language Configuration
DEFAULT_LANGUAGE=pt-BR
SUPPORTED_LANGUAGES=pt-BR,en-US,es-ES,fr-FR,de-DE,it-IT,ja-JP,zh-CN

# Voice Configuration
DEFAULT_VOICE=pt-BR-FranciscaNeural
VOICE_GENDER=Female
VOICE_STYLE=Neutral
